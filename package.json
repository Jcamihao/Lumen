{
  "name": "lumen",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:infra && concurrently -n backend,frontend,selah -c blue,orange,magenta \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:selah\"",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix frontend run start",
    "dev:selah": "node ./scripts/dev-selah.mjs",
    "dev:infra": "docker compose up -d --force-recreate postgres redis",
    "mobile:build": "npm --prefix frontend run build:mobile",
    "mobile:sync": "npm --prefix frontend run cap:sync",
    "mobile:add:ios": "npm --prefix frontend run cap:add:ios",
    "mobile:open:ios": "npm --prefix frontend run cap:open:ios",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down -v",
    "db:seed": "npm --prefix backend run prisma:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
