POSTGRES_DB=lumen
POSTGRES_USER=lumen
POSTGRES_PASSWORD=lumen
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
BACKEND_HOST_PORT=3001
FRONTEND_HOST_PORT=4201

DATABASE_URL=postgresql://lumen:lumen@postgres:5432/lumen?schema=public
DATABASE_URL_LOCAL=postgresql://lumen:lumen@localhost:5433/lumen?schema=public

PORT=3000
APP_URL=http://localhost:3001
APP_CORS_ALLOWED_ORIGINS=http://localhost:4201,http://127.0.0.1:4201,http://localhost:8100,http://127.0.0.1:8100,capacitor://localhost,http://localhost
APP_SWAGGER_ENABLED=true
JWT_ACCESS_SECRET=lumen_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=lumen_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
AUTH_REFRESH_COOKIE_NAME=lumen.refreshToken
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=lax
AUTH_MFA_ENABLED=false
AUTH_MFA_ENCRYPTION_SECRET=lumen_mfa_encryption_secret
AUTH_MFA_ISSUER=LUMEN
AUTH_MFA_CHALLENGE_EXPIRES_IN_SECONDS=300

REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=300
SELAH_ASSISTANT_ENABLED=false
SELAH_BASE_URL=
SELAH_API_KEY=
SELAH_SOURCE_APP=LumenBack
SELAH_ASSISTANT_ROUTE=/v1/adapters/lumen/life-assistant/chat
SELAH_RECEIPT_ROUTE=/v1/adapters/lumen/receipt-parser/parse
SELAH_TIMEOUT_MS=9000

FRONTEND_APP_API_BASE_URL=http://localhost:3001/api/v1
FRONTEND_APP_WS_BASE_URL=http://localhost:3001
FRONTEND_APP_CLIENT_LOGGING_ENABLED=true
FRONTEND_APP_MFA_ENABLED=false
